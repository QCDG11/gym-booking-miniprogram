.container {
  padding: 60rpx 40rpx;
  background: #fff;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

.form {
  width: 100%;
}

.input-group {
  margin-bottom: 40rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 30rpx;
  background: #f5f5f5;
  border-radius: 44rpx;
  font-size: 28rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  line-height: 88rpx;
  margin-top: 40rpx;
}

.toggle {
  text-align: center;
  margin-top: 40rpx;
}

.toggle text {
  color: #1890ff;
  font-size: 28rpx;
}