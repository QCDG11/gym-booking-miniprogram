.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: #1890ff;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 48rpx;
  color: #1890ff;
}

.username {
  color: #fff;
  font-size: 36rpx;
  margin-top: 20rpx;
}

.role {
  color: rgba(255,255,255,0.8);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.menu-list {
  background: #fff;
  margin-top: 20rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-label {
  color: #333;
  font-size: 28rpx;
}

.menu-value {
  color: #999;
  font-size: 28rpx;
}

.btn-logout {
  margin: 40rpx;
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 44rpx;
}