.container { min-height: 100vh; background: #f5f5f5; }
.user-card { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 60rpx 30rpx; display: flex; align-items: center; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 50rpx; color: #fff; font-weight: bold; margin-right: 30rpx; border: 4rpx solid rgba(255,255,255,0.5); }
.user-info { display: flex; flex-direction: column; }
.nickname { font-size: 36rpx; color: #fff; font-weight: bold; }
.role { font-size: 24rpx; color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.2); padding: 6rpx 20rpx; border-radius: 20rpx; margin-top: 12rpx; display: inline-block; width: fit-content; }
.info-section { background: #fff; margin: 20rpx; border-radius: 20rpx; padding: 0 30rpx; }
.info-item { display: flex; justify-content: space-between; padding: 30rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.info-item:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: #666; }
.info-value { font-size: 28rpx; color: #333; }
.menu-section { background: #fff; margin: 20rpx; border-radius: 20rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.menu-item:last-child { border-bottom: none; }
.menu-left { display: flex; align-items: center; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-name { font-size: 28rpx; color: #333; }
.menu-arrow { color: #ccc; font-size: 28rpx; }
.logout-section { padding: 30rpx; }
.btn-logout { background: #fff; color: #ff4d4f; border: none; font-size: 28rpx; padding: 24rpx; border-radius: 20rpx; }