.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.banner {
  height: 350rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.quick-actions {
  background: #fff;
  padding: 40rpx 20rpx;
  margin-bottom: 20rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
}

.action-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  background: #e6f7ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.iconfont {
  font-size: 40rpx;
}

.action-name {
  font-size: 24rpx;
  color: #666;
}

.section {
  background: #fff;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-content {
  min-height: 100rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}