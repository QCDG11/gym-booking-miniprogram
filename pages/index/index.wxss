.container { min-height: 100vh; background-color: #f5f5f5; }

.header { 
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); 
  padding: 50rpx 30rpx 80rpx; 
  border-radius: 0 0 40rpx 40rpx; 
}

.user-card { display: flex; align-items: center; margin-bottom: 40rpx; }

.avatar { 
  width: 100rpx; height: 100rpx; border-radius: 50%; 
  background: rgba(255,255,255,0.25); 
  display: flex; align-items: center; justify-content: center; 
  font-size: 44rpx; color: #fff; font-weight: bold; 
  margin-right: 24rpx; 
}

.user-info { display: flex; flex-direction: column; }

.nickname { font-size: 36rpx; color: #fff; font-weight: bold; }

.role { 
  font-size: 22rpx; color: rgba(255,255,255,0.85); 
  background: rgba(255,255,255,0.2); 
  padding: 6rpx 18rpx; border-radius: 20rpx; 
  margin-top: 10rpx; width: fit-content; 
}

.stats-row { 
  background: rgba(255,255,255,0.15); border-radius: 20rpx; 
  padding: 28rpx; display: flex; 
  align-items: center; justify-content: space-around; 
}

.stat-item { display: flex; flex-direction: column; align-items: center; }

.stat-num { font-size: 44rpx; color: #fff; font-weight: bold; }

.stat-label { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; }

.stat-divider { width: 2rpx; height: 50rpx; background: rgba(255,255,255,0.3); }

.section { padding: 30rpx; }

.section-title { font-size: 32rpx; color: #333; font-weight: bold; margin-bottom: 24rpx; }

/* 2x2网格布局 */
.action-grid { 
  display: flex; 
  flex-wrap: wrap; 
  justify-content: space-between; 
}

.action-item { 
  width: 48%;  /* 两列，每列占48% */
  background-color: #ffffff; 
  border-radius: 20rpx; 
  padding: 30rpx 24rpx; 
  display: flex; 
  align-items: center; 
  margin-bottom: 20rpx; 
  box-sizing: border-box;
}

.action-icon { 
  width: 72rpx; height: 72rpx; border-radius: 18rpx; 
  display: flex; align-items: center; justify-content: center; 
  font-size: 36rpx; margin-right: 20rpx; flex-shrink: 0; 
}

.action-name { font-size: 28rpx; color: #333; font-weight: 500; }

.recommend-card { 
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); 
  border-radius: 20rpx; padding: 28rpx; 
  display: flex; justify-content: space-between; align-items: center; 
}

.recommend-info { display: flex; flex-direction: column; }

.recommend-title { font-size: 32rpx; color: #fff; font-weight: bold; }

.recommend-desc { font-size: 24rpx; color: rgba(255,255,255,0.85); margin-top: 6rpx; }

.recommend-btn { 
  background-color: #ffffff; color: #f5576c; 
  padding: 14rpx 28rpx; border-radius: 28rpx; 
  font-size: 24rpx; font-weight: bold; 
}