.container { min-height: 100vh; background: #f5f5f5; }
.header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40rpx 30rpx 60rpx; border-radius: 0 0 40rpx 40rpx; }
.user-card { display: flex; align-items: center; margin-bottom: 40rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 40rpx; color: #fff; font-weight: bold; margin-right: 20rpx; }
.user-info { display: flex; flex-direction: column; }
.nickname { font-size: 36rpx; color: #fff; font-weight: bold; }
.role { font-size: 24rpx; color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.2); padding: 4rpx 16rpx; border-radius: 20rpx; margin-top: 8rpx; display: inline-block; }
.stats-row { background: rgba(255,255,255,0.15); border-radius: 20rpx; padding: 30rpx; display: flex; align-items: center; justify-content: space-around; }
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 48rpx; color: #fff; font-weight: bold; }
.stat-label { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }
.stat-divider { width: 2rpx; height: 60rpx; background: rgba(255,255,255,0.3); }
.section { padding: 30rpx; }
.section-title { font-size: 32rpx; color: #333; font-weight: bold; margin-bottom: 24rpx; }
.action-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.action-item { width: 48%; background: #fff; border-radius: 24rpx; padding: 30rpx; display: flex; align-items: center; margin-bottom: 20rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05); }
.action-icon { width: 80rpx; height: 80rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; margin-right: 20rpx; flex-shrink: 0; }
.action-name { font-size: 28rpx; color: #333; font-weight: 500; }
.recommend-card { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); border-radius: 24rpx; padding: 30rpx; display: flex; justify-content: space-between; align-items: center; }
.recommend-info { display: flex; flex-direction: column; }
.recommend-title { font-size: 32rpx; color: #fff; font-weight: bold; }
.recommend-desc { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }
.recommend-btn { background: #fff; color: #f5576c; padding: 16rpx 30rpx; border-radius: 30rpx; font-size: 24rpx; font-weight: bold; }