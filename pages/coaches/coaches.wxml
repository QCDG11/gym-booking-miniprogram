<view class="container">
  <view class="coach-list">
    <block wx:for="{{coaches}}" wx:key="id">
      <view class="coach-item" bindtap="onSelectCoach" data-coach="{{item}}">
        <view class="coach-info">
          <text class="coach-name">{{item.name}}</text>
          <text class="coach-specialty">{{item.specialty}}</text>
        </view>
        <text class="arrow">></text>
      </view>
    </block>
  </view>
  <view class="empty" wx:if="{{coaches.length === 0}}">暂无私教</view>
</view>