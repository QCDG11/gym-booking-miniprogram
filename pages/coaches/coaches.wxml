<view class="container">
  <view class="coach-list">
    <block wx:for="{{coaches}}" wx:key="id">
      <view class="coach-card" bindtap="onSelectCoach" data-coach="{{item}}">
        <view class="coach-avatar">{{item.name[0]}}</view>
        <view class="coach-info">
          <text class="coach-name">{{item.name}}</text>
          <text class="coach-specialty">{{item.specialty}}</text>
          <text class="coach-intro">{{item.introduction}}</text>
          <text class="coach-exp">从业 {{item.yearsOfExperience}} 年</text>
        </view>
        <view class="coach-arrow">></view>
      </view>
    </block>
  </view>
  <view class="empty" wx:if="{{coaches.length === 0}}">
    <text>暂无私教</text>
  </view>
</view>

<!-- 购买弹窗 -->
<view class="modal-mask" wx:if="{{showModal}}" bindtap="onCloseModal"></view>
<view class="modal" wx:if="{{showModal}}">
  <view class="modal-header">
    <text class="modal-title">购买私教课程</text>
    <text class="modal-close" bindtap="onCloseModal">×</text>
  </view>
  <view class="modal-body">
    <view class="form-item">
      <text class="form-label">私教</text>
      <text class="form-value">{{selectedCoach.name}}</text>
    </view>
    <view class="form-item">
      <text class="form-label">课程类型</text>
      <picker mode="selector" range="{{['增肌', '减脂', '塑形', '康复', '拳击']}}" bindchange="onInputChange" data-field="type">
        <view class="picker">{{form.type}}</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">时长(分钟)</text>
      <input class="form-input" type="number" value="{{form.duration}}" bindinput="onInputChange" data-field="duration" />
    </view>
    <view class="form-item">
      <text class="form-label">课程节数</text>
      <input class="form-input" type="number" value="{{form.totalSessions}}" bindinput="onInputChange" data-field="totalSessions" />
    </view>
    <view class="form-item">
      <text class="form-label">价格(元)</text>
      <input class="form-input" type="number" value="{{form.price}}" bindinput="onInputChange" data-field="price" />
    </view>
  </view>
  <view class="modal-footer">
    <button class="btn-cancel" bindtap="onCloseModal">取消</button>
    <button class="btn-confirm" bindtap="onConfirm">确认购买</button>
  </view>
</view>