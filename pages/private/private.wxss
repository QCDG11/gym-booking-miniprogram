.container { padding: 20rpx; }
.section { margin-bottom: 30rpx; }
.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 16rpx; }
.list { background: #fff; border-radius: 8rpx; }
.item { padding: 24rpx; border-bottom: 1rpx solid #eee; display: flex; align-items: center; }
.item text { flex: 1; }
.name { font-size: 28rpx; }
.desc { font-size: 24rpx; color: #666; }
.empty { text-align: center; padding: 60rpx; color: #999; }