<view class="container">
  <!-- Tab切换 -->
  <view class="tabs">
    <view class="tab {{activeTab === 'trainings' ? 'active' : ''}}" bindtap="onTabChange" data-tab="trainings">
      我的私教
    </view>
    <view class="tab {{activeTab === 'bookings' ? 'active' : ''}}" bindtap="onTabChange" data-tab="bookings">
      预约记录
    </view>
  </view>

  <!-- 我的私教课程 -->
  <view class="content" wx:if="{{activeTab === 'trainings'}}">
    <block wx:for="{{privateTrainings}}" wx:key="id">
      <view class="training-card">
        <view class="training-header">
          <text class="training-type">{{item.type}}</text>
          <text class="training-status">{{item.status}}</text>
        </view>
        <view class="training-info">
          <text class="training-coach">教练: {{item.coach ? item.coach.name : '-'}}</text>
          <text class="training-sessions">剩余 {{item.remainingSessions}} / {{item.totalSessions}} 节</text>
          <text class="training-expire">有效期至: {{item.expireDate}}</text>
        </view>
        <view class="training-actions">
          <button class="btn-book" bindtap="onBookSession" data-training="{{item}}" disabled="{{item.remainingSessions <= 0}}">
            {{item.remainingSessions > 0 ? '预约课程' : '次数已用完'}}
          </button>
        </view>
      </view>
    </block>
    <view class="empty" wx:if="{{privateTrainings.length === 0}}">
      <text>暂无私教课程</text>
    </view>
  </view>

  <!-- 预约记录 -->
  <view class="content" wx:if="{{activeTab === 'bookings'}}">
    <block wx:for="{{privateBookings}}" wx:key="id">
      <view class="booking-card">
        <view class="booking-info">
          <text class="booking-time">预约时间: {{item.bookedTime}}</text>
          <text class="booking-location">地点: {{item.location}}</text>
          <text class="booking-note">备注: {{item.note || '-'}}</text>
          <text class="booking-status">状态: {{item.status}}</text>
        </view>
        <view class="booking-actions" wx:if="{{item.status === 'CONFIRMED'}}">
          <button class="btn-cancel" bindtap="onCancel" data-id="{{item.id}}">取消</button>
        </view>
      </view>
    </block>
    <view class="empty" wx:if="{{!privateBookings || privateBookings.length === 0}}">
      <text>暂无预约记录</text>
    </view>
  </view>
</view>

<!-- 预约弹窗 -->
<view class="modal-mask" wx:if="{{showBookingModal}}" bindtap="onCloseModal"></view>
<view class="modal" wx:if="{{showBookingModal}}">
  <view class="modal-header">
    <text class="modal-title">预约私教课程</text>
    <text class="modal-close" bindtap="onCloseModal">×</text>
  </view>
  <view class="modal-body">
    <view class="form-item">
      <text class="form-label">剩余次数</text>
      <text class="form-value">{{selectedTraining.remainingSessions}} 节</text>
    </view>
    <view class="form-item">
      <text class="form-label">预约时间</text>
      <picker mode="date" bindchange="onDateChange" data-field="bookedTime">
        <view class="picker">{{bookingForm.bookedTime || '请选择日期'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">地点</text>
      <input class="form-input" value="{{bookingForm.location}}" bindinput="onInputChange" data-field="location" />
    </view>
    <view class="form-item">
      <text class="form-label">备注</text>
      <input class="form-input" value="{{bookingForm.note}}" bindinput="onInputChange" data-field="note" placeholder="请输入备注" />
    </view>
  </view>
  <view class="modal-footer">
    <button class="btn-cancel" bindtap="onCloseModal">取消</button>
    <button class="btn-confirm" bindtap="onConfirmBooking">确认预约</button>
  </view>
</view>