<view class="container">
  <view class="tabs">
    <view class="tab {{activeTab === 'trainings' ? 'active' : ''}}" bindtap="onTabChange" data-tab="trainings">我的私教</view>
    <view class="tab {{activeTab === 'bookings' ? 'active' : ''}}" bindtap="onTabChange" data-tab="bookings">预约记录</view>
  </view>

  <view class="content" wx:if="{{activeTab === 'trainings'}}">
    <block wx:for="{{privateTrainings}}" wx:key="id">
      <view class="training-card">
        <view class="training-header">
          <text class="training-type">{{item.type}}</text>
          <text class="training-status">{{item.status === 'ACTIVE' ? '进行中' : item.status}}</text>
        </view>
        <view class="training-info">
          <text>教练: {{item.coach ? item.coach.name : '-'}}</text>
          <text>剩余 {{item.remainingSessions}} / {{item.totalSessions}} 节</text>
          <text>有效期至: {{item.expireDate}}</text>
        </view>
        <view class="training-action">
          <button class="btn-book" bindtap="onBookSession" data-training="{{item}}" disabled="{{item.remainingSessions <= 0}}">
            {{item.remainingSessions > 0 ? '预约课程' : '次数用完'}}
          </button>
        </view>
      </view>
    </block>
    <view class="empty" wx:if="{{privateTrainings.length === 0}}">
      <text>暂无私教课程</text>
      <button class="btn-go" bindtap="goToCoaches">去购买</button>
    </view>
  </view>

  <view class="content" wx:if="{{activeTab === 'bookings'}}">
    <block wx:for="{{privateBookings}}" wx:key="id">
      <view class="booking-card">
        <view class="booking-info">
          <text class="booking-time">🕐 {{item.bookedTime}}</text>
          <text class="booking-location">📍 {{item.location}}</text>
          <text class="booking-note">📝 {{item.note || '无备注'}}</text>
        </view>
        <view class="booking-status-row">
          <text class="booking-status {{item.status === 'CONFIRMED' ? 'confirmed' : ''}}">{{item.status === 'CONFIRMED' ? '已预约' : '已取消'}}</text>
          <button class="btn-cancel" wx:if="{{item.status === 'CONFIRMED'}}" bindtap="onCancel" data-id="{{item.id}}">取消</button>
        </view>
      </view>
    </block>
    <view class="empty" wx:if="{{!privateBookings || privateBookings.length === 0}}">
      <text>暂无预约记录</text>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showModal}}" bindtap="onCloseModal"></view>
<view class="modal" wx:if="{{showModal}}">
  <view class="modal-header">
    <text class="modal-title">预约私教课程</text>
    <text class="modal-close" bindtap="onCloseModal">×</text>
  </view>
  <view class="modal-body">
    <view class="form-item">
      <text class="form-label">剩余次数</text>
      <text class="form-value">{{selectedTraining.remainingSessions}} 节</text>
    </view>
    <view class="form-item">
      <text class="form-label">预约时间</text>
      <picker mode="date" bindchange="onDateChange">
        <view class="picker">{{form.bookedTime || '请选择日期'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">地点</text>
      <input class="form-input" value="{{form.location}}" bindinput="onInputChange" data-field="location" />
    </view>
    <view class="form-item">
      <text class="form-label">备注</text>
      <input class="form-input" value="{{form.note}}" bindinput="onInputChange" data-field="note" placeholder="请输入备注" />
    </view>
  </view>
  <view class="modal-footer">
    <button class="btn-cancel" bindtap="onCloseModal">取消</button>
    <button class="btn-confirm" bindtap="onConfirm">确认预约</button>
  </view>
</view>