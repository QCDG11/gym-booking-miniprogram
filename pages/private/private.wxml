<view class="container">
  <view class="section">
    <view class="section-title">我的私教</view>
    <view class="list">
      <view class="item" wx:for="{{privateTrainings}}" wx:key="id">
        <text class="name">{{item.type}}</text>
        <text class="desc">剩余 {{item.remainingSessions}}/{{item.totalSessions}} 节</text>
        <button size="mini" bindtap="onBookSession" data-training="{{item}}">预约</button>
      </view>
      <view wx:if="{{privateTrainings.length === 0}}" class="empty">暂无私教课程</view>
    </view>
  </view>
  <view class="section">
    <view class="section-title">预约记录</view>
    <view class="list">
      <view class="item" wx:for="{{privateBookings}}" wx:key="id">
        <text class="name">{{item.bookedTime}}</text>
        <text class="desc">{{item.location}}</text>
      </view>
      <view wx:if="{{!privateBookings || privateBookings.length === 0}}" class="empty">暂无记录</view>
    </view>
  </view>
</view>