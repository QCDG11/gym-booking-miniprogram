<view class="container">
  <view class="section">
    <view class="section-title">课程预约</view>
    <view class="booking-list">
      <view class="booking-item" wx:for="{{courseBookings}}" wx:key="id">
        <view class="booking-info">
          <text class="booking-name">{{item.schedule.course.name}}</text>
          <text class="booking-time">{{item.schedule.startTime}}</text>
          <text class="booking-status">{{item.status}}</text>
        </view>
        <button class="btn-cancel" wx:if="{{item.status === 'CONFIRMED'}}" bindtap="onCancel" data-id="{{item.id}}" data-type="course">取消</button>
      </view>
      <view wx:if="{{courseBookings.length === 0}}" class="empty">暂无预约</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">私教预约</view>
    <view class="booking-list">
      <view class="booking-item" wx:for="{{privateBookings}}" wx:key="id">
        <view class="booking-info">
          <text class="booking-name">{{item.privateTraining.type}}</text>
          <text class="booking-time">{{item.bookedTime}}</text>
          <text class="booking-status">{{item.status}}</text>
        </view>
        <button class="btn-cancel" wx:if="{{item.status === 'CONFIRMED'}}" bindtap="onCancel" data-id="{{item.id}}" data-type="private">取消</button>
      </view>
      <view wx:if="{{privateBookings.length === 0}}" class="empty">暂无预约</view>
    </view>
  </view>
</view>