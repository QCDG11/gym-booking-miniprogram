<view class="container">
  <!-- Tab切换 -->
  <view class="tabs">
    <view class="tab {{activeTab === 'course' ? 'active' : ''}}" bindtap="onTabChange" data-tab="course">课程预约</view>
    <view class="tab {{activeTab === 'private' ? 'active' : ''}}" bindtap="onTabChange" data-tab="private">私教预约</view>
  </view>

  <!-- 课程预约列表 -->
  <view class="content" wx:if="{{activeTab === 'course'}}">
    <block wx:for="{{courseBookings}}" wx:key="id">
      <view class="booking-card">
        <view class="booking-header">
          <text class="booking-title">{{item.courseName || '课程预约'}}</text>
          <text class="booking-status {{item.status === 'CONFIRMED' ? 'confirmed' : 'cancelled'}}">{{item.status === 'CONFIRMED' ? '已预约' : '已取消'}}</text>
        </view>
        <view class="booking-body">
          <text class="booking-info">🕐 {{item.startTime}}</text>
          <text class="booking-info">📍 {{item.location}}</text>
          <text class="booking-info">👨‍🏫 {{item.coachName}}</text>
        </view>
        <view class="booking-footer" wx:if="{{item.status === 'CONFIRMED'}}">
          <button class="btn-cancel" bindtap="onCancel" data-id="{{item.id}}" data-type="course">取消预约</button>
        </view>
      </view>
    </block>
    <view class="empty" wx:if="{{courseBookings.length === 0}}">
      <text class="empty-icon">📋</text>
      <text>暂无课程预约</text>
      <button class="btn-go" bindtap="goToCourses">去预约</button>
    </view>
  </view>

  <!-- 私教预约列表 -->
  <view class="content" wx:if="{{activeTab === 'private'}}">
    <block wx:for="{{privateTrainings}}" wx:key="id">
      <view class="booking-card">
        <view class="booking-header">
          <text class="booking-title">{{item.type}}</text>
          <text class="booking-status {{item.status === 'ACTIVE' ? 'confirmed' : 'cancelled'}}">{{item.status === 'ACTIVE' ? '进行中' : item.status}}</text>
        </view>
        <view class="booking-body">
          <text class="booking-info">👨‍🏫 教练: {{item.coachName || '-'}}</text>
          <text class="booking-info">📊 剩余 {{item.remainingSessions}} / {{item.totalSessions}} 节</text>
          <text class="booking-info">⏰ 有效期至: {{item.expireDate}}</text>
        </view>
      </view>
    </block>
    <view class="empty" wx:if="{{!privateTrainings || privateTrainings.length === 0}}">
      <text class="empty-icon">💪</text>
      <text>暂无私教课程</text>
      <button class="btn-go" bindtap="goToCoaches">去购买</button>
    </view>
  </view>
</view>