.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.tabs {
  display: flex;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #667eea;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #667eea;
  border-radius: 3rpx;
}

.content {
  padding: 20rpx;
}

.schedule-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.schedule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.schedule-card .course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.schedule-status {
  font-size: 24rpx;
  color: #667eea;
  background: #f0f4ff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.schedule-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.schedule-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.info-item {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.btn-book {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  border: none;
}

.btn-full {
  background: #ccc;
  color: #fff;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  border: none;
}

.course-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.course-card .course-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.course-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.course-meta {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.course-price {
  font-size: 36rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}